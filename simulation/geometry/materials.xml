<materials>

  <!-- Air (uses elements N, O, C, Ar — all defined in elements.xml) -->
  <material name="Air" state="gas">
    <D unit="g/cm3" value="0.00120479"/>
    <fraction n="0.000124" ref="C"/>
    <fraction n="0.755268" ref="N"/>
    <fraction n="0.231781" ref="O"/>
    <fraction n="0.012827" ref="Ar"/>
  </material>

  <!-- Vacuum -->
  <material name="Vacuum" state="gas">
    <D unit="g/cm3" value="1e-25"/>
    <fraction n="1.0" ref="N"/>
  </material>

  <!-- CarbonFiber — ECAL slab structural layer -->
  <material name="CarbonFiber" state="solid">
    <D unit="g/cm3" value="1.46667"/>
    <fraction n="0.794092" ref="C"/>
    <fraction n="0.058409" ref="H"/>
    <fraction n="0.147499" ref="O"/>
  </material>

  <!-- PCB (FR4) — ECAL readout board -->
  <material name="PCB" state="solid">
    <D unit="g/cm3" value="1.7"/>
    <fraction n="0.180774" ref="Si"/>
    <fraction n="0.405633" ref="O"/>
    <fraction n="0.278042" ref="C"/>
    <fraction n="0.068443" ref="H"/>
    <fraction n="0.067109" ref="Br"/>
  </material>

  <!-- TungstenDens1910 — ECAL absorber: >=99.95% W, density 19.10 g/cm3 -->
  <material name="TungstenDens1910">
    <D value="19.10" unit="g/cm3"/>
    <fraction n="1.0" ref="W"/>
  </material>

  <!-- Polyvinyltoluene plastic scintillator (BC-408 / EJ-200 equivalent) -->
  <material name="Scintillator" state="solid">
    <D unit="g/cm3" value="1.032"/>
    <fraction n="0.915" ref="C"/>
    <fraction n="0.085" ref="H"/>
  </material>

  <!-- Nuclear emulsion (FairShip media.geo 'NuclearEmulsion', rho=2.90 g/cm3).
       FairShip's raw mass fractions sum to ~1.222; normalized here to 1. -->
  <material name="NuclearEmulsion" state="solid">
    <D unit="g/cm3" value="2.90"/>
    <fraction n="0.36576" ref="Ag"/>
    <fraction n="0.27003" ref="Br"/>
    <fraction n="0.18247" ref="C"/>
    <fraction n="0.07021" ref="O"/>
    <fraction n="0.06710" ref="N"/>
    <fraction n="0.02594" ref="H"/>
    <fraction n="0.01293" ref="I"/>
    <fraction n="0.00434" ref="S"/>
    <fraction n="0.00074" ref="Si"/>
    <fraction n="0.00041" ref="Na"/>
    <fraction n="0.00008" ref="Sr"/>
  </material>

  <!-- Emulsion film plastic base (FairShip 'PlasticBase') -->
  <material name="PlasticBase" state="solid">
    <D unit="g/cm3" value="1.28"/>
    <fraction n="0.5075" ref="O"/>
    <fraction n="0.4286" ref="C"/>
    <fraction n="0.0639" ref="H"/>
  </material>

  <!-- Non-magnetic austenitic stainless steel (AISI 304) for the MTC
       absorber filler around the magnetic iron core -->
  <material name="Steel" state="solid">
    <D unit="g/cm3" value="8.02"/>
    <fraction n="0.70" ref="Fe"/>
    <fraction n="0.19" ref="Cr"/>
    <fraction n="0.09" ref="Ni"/>
    <fraction n="0.02" ref="Mn"/>
  </material>

</materials>
