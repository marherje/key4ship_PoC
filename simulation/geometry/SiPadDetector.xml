<detector name="SiPad" type="SiPadDetector" vis="EcalVis" id="1"
          readout="SiPadHits" insideTrackingVolume="false">

  <dimensions x="SiPad_dim_x" y="SiPad_dim_y" z="SiPad_dim_z"/>

  <type_flags type="DetType_TRACKER + DetType_BARREL + DetType_PIXEL"/>

  <envelope vis="EcalVis">
    <shape type="Box"
           dx="SiPad_dim_x/2.0 + env_safety"
           dy="SiPad_dim_y/2.0 + env_safety"
           dz="SiPad_dim_z/2.0 + env_safety"
           material="Air"/>
    <rotation x="0" y="0" z="0"/>
    <position x="0" y="0" z="SiPad_z_position"/>
  </envelope>

  <!-- Layers 2-4: W(1.40x) + W(4.20x) + CF + Cu + glue + Si(650um) + glue + Cu + PCB + chip + gap -->
  <layer repeat="SiPad_NLayers" vis="EcalVis">
    <slice material="TungstenDens1910" thickness="SiPad_WThickness"   vis="TungstenVis"/>
    <slice material="CarbonFiber"     thickness="SiPad_CFThickness"        vis="CFVis"/>
    <slice material="Copper"          thickness="SiPad_KaptonThickness"    vis="CuVis"/>
    <slice material="Air"             thickness="SiPad_GlueThickness_kap"  vis="AirVis"/>
    <slice material="Silicon"         thickness="SiPad_WaferThickness650"  vis="SiVis" sensitive="yes"/>
    <slice material="Air"             thickness="SiPad_GlueThickness_pcb"  vis="AirVis"/>
    <slice material="Copper"          thickness="SiPad_KaptonThickness"    vis="CuVis"/>
    <slice material="PCB"             thickness="SiPad_PcbThickness"       vis="PCBVis"/>
    <slice material="Air"             thickness="SiPad_ChipThickness"      vis="AirVis"/>
    <slice material="Air"             thickness="SiPad_layer_gap"      vis="AirVis"/>
  </layer>

</detector>
