<lccdd xmlns:compact="http://www.lcsim.org/schemas/compact/1.0"
       xmlns:xs="http://www.w3.org/2001/XMLSchema"
       xs:noNamespaceSchemaLocation="http://www.lcsim.org/schemas/compact/1.0/compact.xsd">

  <info name="SND_sim_poc" title="SND simulation proof-of-concept" author="J.P. Marquez"
        url="" status="development" version="1.0">
    <comment> key4hep 2026-02-01 compatible </comment>
  </info>

  <includes>
    <gdmlFile ref="elements.xml"/>
    <gdmlFile ref="materials.xml"/>
  </includes>

  <define>
    <!-- Detector type flag constants from DD4hep DetType.h -->
    <!-- These are needed by ACTS convertDD4hepDetector to classify subdetectors -->
    <!-- <constant name="DetType_TRACKER"  value="0x1"/> -->
    <!-- <constant name="DetType_BARREL"   value="0x10"/> -->
    <!-- <constant name="DetType_STRIP"    value="0x80"/> -->
    <!-- <constant name="DetType_PIXEL"    value="0x100"/> -->

    <!-- World -->
    <constant name="world_side" value="20*m"/>
    <constant name="world_x"    value="world_side"/>
    <constant name="world_y"    value="world_side"/>
    <constant name="world_z"    value="world_side"/>
    <constant name="env_safety"               value="0.001*mm"/>

    <!-- Required by DD4hep tracking region -->
    <constant name="tracker_region_rmax" value="0*mm"/>
    <constant name="tracker_region_zmax" value="0*mm"/>

    <!-- Input parameters -->
    <constant name="SiPad_WThickness"        value="10*mm"/>
    <constant name="SiTarget_WThickness"     value="3.5*mm"/>
    <constant name="SiPad_dim_z"              value="200*mm"/>


    <!-- Directly derived parameters -->
    <constant name="SiTarget_dim_z"          value="1700*mm-SiPad_dim_z"/>
    <constant name="SiTarget_z_position"     value="-SiTarget_dim_z/2.0-SiPad_dim_z"/>


    <!-- ECAL geometry constants (from SiPad_commondefs.xml) -->
    <constant name="SiPad_z_position"         value="-SiPad_dim_z/2.0"/>
    <constant name="SiPad_NcellsX"            value="32"/> <!-- per sensor -->
    <constant name="SiPad_NcellsY"            value="32"/> <!-- per sensor -->
    <constant name="SiPad_CellSizeX"          value="5.625*mm"/>
    <constant name="SiPad_CellSizeY"          value="5.625*mm"/>
    <constant name="SiPad_dim_x"              value="3*SiPad_NcellsX*SiPad_CellSizeX"/> <!-- array of sensors -->
    <constant name="SiPad_dim_y"              value="3*SiPad_NcellsY*SiPad_CellSizeY"/> <!-- array of sensors -->
    <constant name="SiPad_CFThickness"        value="1.5*mm"/>
    <constant name="SiPad_KaptonThickness"    value="0.1*mm"/>
    <constant name="SiPad_GlueThickness_kap"  value="0.1*mm"/>
    <constant name="SiPad_GlueThickness_pcb"  value="0.1*mm"/>
    <constant name="SiPad_WaferThickness650"  value="0.65*mm"/>
    <constant name="SiPad_PcbThickness"       value="1.7*mm"/>
    <constant name="SiPad_ChipThickness"      value="1.2*mm"/>
    <constant name="SiPad_layer_gap"         value="1*mm"/>
    <constant name="SiPad_LayerThickness"      value="SiPad_WThickness+SiPad_layer_gap+SiPad_CFThickness+SiPad_KaptonThickness+SiPad_GlueThickness_kap+SiPad_WaferThickness650+SiPad_GlueThickness_pcb+SiPad_KaptonThickness+SiPad_PcbThickness+SiPad_ChipThickness"/>
    <constant name="SiPad_NLayers"            value="floor(SiPad_dim_z/SiPad_LayerThickness)"/>

    <!-- SiTarget constants (from FairShip SiliconTarget_config.yaml) -->
    <constant name="SiTarget_strip_pitch"    value="0.0755*mm"/>
    <constant name="SiTarget_module_offset"  value="1*mm"/> <!-- From W to Si planes -->
    <constant name="SiTarget_spacing"         value="11.0*mm"/> <!-- Between W planes -->
    <constant name="SiTarget_sensor_thickness" value="0.3*mm"/>
    <constant name="SiTarget_XY_plane_gap" value="SiTarget_spacing-SiTarget_WThickness-2*SiTarget_module_offset-2*SiTarget_sensor_thickness"/>
    <constant name="SiTarget_env_width"      value="400*mm"/>
    <constant name="SiTarget_env_height"     value="400*mm"/>
    <constant name="SiTarget_LayerThickness"      value="SiTarget_spacing"/>
    <!-- SiTarget sensor layout: 4 columns x 2 rows per plane (square sensors) -->
    <constant name="SiTarget_sensor_width"    value="99.25*mm"/>  <!-- active X -->
    <constant name="SiTarget_sensor_height"   value="199.5*mm"/>  <!-- active Y -->
    <constant name="SiTarget_sensor_gap"      value="1.0*mm"/>    <!-- gap between sensors -->
    <constant name="SiTarget_ncols"           value="4"/>
    <constant name="SiTarget_nrows"           value="2"/>
    <constant name="SiTarget_NLayers"       value="floor(SiTarget_dim_z/SiTarget_LayerThickness)"/>

    <!-- MTC shared layer constants (hardcoded values from MTCDetector.h unless noted) -->
    <constant name="MTC_FeThickness"         value="50.0*mm"/>  <!-- outer iron absorber, PoC default -->
    <constant name="MTC_InnerIronThickness"  value="3.0*mm"/>   <!-- lowerIronThick = upperIronThick -->
    <constant name="MTC_SciFiThickness"      value="1.35*mm"/>  <!-- fiberMatThick per plane -->
    <constant name="MTC_XY_plane_gap"        value="1.0*mm"/>   <!-- airGap between U and V planes -->
    <constant name="MTC_ScintThickness"      value="15.0*mm"/>
    <constant name="MTC_layer_gap"           value="1.0*mm"/>
    <constant name="MTC_NLayers"             value="14"/>
    <constant name="MTC_fiber_angle_deg"     value="5"/>        <!-- dimensionless degrees, converted in plugin -->
    <constant name="MTC_ScintCellSize"       value="50.0*mm"/>
    <constant name="MTC_SciFiChannelSize"    value="1.0*mm"/>   <!-- PoC placeholder, tune later -->
    <constant name="MTC_max_env_width"       value="600.0*mm"/>

    <constant name="MTC_layer_thickness" value="MTC_FeThickness + MTC_InnerIronThickness + MTC_SciFiThickness + MTC_XY_plane_gap + MTC_SciFiThickness + MTC_InnerIronThickness + MTC_ScintThickness + MTC_layer_gap"/>
    <constant name="MTC_total_length"    value="MTC_NLayers * MTC_layer_thickness"/>

    <!-- Per-station transverse dimensions -->
    <constant name="MTC40_env_width"     value="600.0*mm"/>
    <constant name="MTC40_env_height"    value="600.0*mm"/>
    <constant name="MTC50_env_width"     value="600.0*mm"/>
    <constant name="MTC50_env_height"    value="600.0*mm"/>
    <constant name="MTC60_env_width"     value="600.0*mm"/>
    <constant name="MTC60_env_height"    value="600.0*mm"/>

    <!-- Z centres: gap of 600 mm after SiPad downstream face, stations back-to-back.
         MTC_inter_station_gap avoids the 0.2 mm envelope overlap (2 × 0.1 mm plugin safety). -->
    <constant name="MTC_inter_station_gap" value="1.0*mm"/>
    <constant name="MTC40_z_position"    value="MTC_total_length/2.0 + MTC_inter_station_gap"/>
    <constant name="MTC50_z_position"    value="MTC40_z_position + MTC_total_length + MTC_inter_station_gap"/>
    <constant name="MTC60_z_position"    value="MTC50_z_position + MTC_total_length + MTC_inter_station_gap"/>

    <!-- Magnetic field in MTC outer iron absorbers -->
    <constant name="MTC_BFieldY" value="1.7*tesla"/>
  </define>

  <limits>
    <limitset name="cal_limits">
      <limit name="step_length_max" particles="*" value="3.0" unit="mm"/>
    </limitset>
  </limits>

  <display>
    <vis name="Invisible"    alpha="0.0" r="0"   g="0"    b="0"    showDaughters="false" visible="false"/>
    <vis name="EcalVis"      alpha="0.1" r="0.7" g="0.7"  b="0.0"  showDaughters="true"  visible="false"/>
    <vis name="TungstenVis"  alpha="0.5" r="0.5" g="0.35" b="0.55" showDaughters="true"  visible="true"/>
    <vis name="AirVis"       alpha="0.01" r="1.0" g="1.0"  b="1.0"  showDaughters="true"  visible="false"/>
    <vis name="SiVis"        alpha="0.5" r="0.9" g="0.9"  b="0.9"  showDaughters="true"  visible="true"/>
    <vis name="AlVis"        alpha="0.1" r="0.7" g="0.7"  b="0.7"  showDaughters="true"  visible="true"/>
    <vis name="PCBVis"       alpha="0.1" r="0.0" g="0.8"  b="0.0"  showDaughters="true"  visible="true"/>
    <vis name="CFVis"        alpha="0.1" r="0.0" g="0.0"  b="0.0"  showDaughters="true"  visible="false"/>
    <vis name="CuVis"        alpha="0.1" r="1.0" g="0.5"  b="0.0"  showDaughters="true"  visible="false"/>
  </display>

  <readouts>
    <readout name="SiPadHits">
      <segmentation type="CartesianGridXY"
                    grid_size_x="SiPad_CellSizeX"
                    grid_size_y="SiPad_CellSizeY"
                    offset_x="-(Ecal_dim_x-Ecal_CellSizeX)/2.0" 
                    offset_y="-(Ecal_dim_y-Ecal_CellSizeY)/2.0"/>
      <id>system:8,layer:8,slice:4,x:9,y:9</id>
    </readout>

    <!-- MTC unified readout: plane=0 (SciFi U), plane=1 (SciFi V), plane=2 (Scint).
         CartesianStripX writes to 'strip'; CartesianGridXY writes to 'x','y'.
         For SciFi hits: strip=channel, x=0, y=0.
         For Scint hits: strip=0, x=cell_x, y=cell_y.
         Downstream split happens in EventShuffler based on the plane field. -->
    <readout name="MTCDetHits">
      <segmentation type="MultiSegmentation" key="plane">
        <segmentation type="CartesianStripXStereo"
                      key_value="0"
                      strip_size_x="MTC_SciFiChannelSize"
                      offset_x="-(MTC_max_env_width/2.0)+0.001*mm"
                      stereo_angle="5.0"/>
        <segmentation type="CartesianStripXStereo"
                      key_value="1"
                      strip_size_x="MTC_SciFiChannelSize"
                      offset_x="-(MTC_max_env_width/2.0)+0.001*mm"
                      stereo_angle="-5.0"/>
        <segmentation type="CartesianGridXY"
                      key_value="2"
                      grid_size_x="MTC_ScintCellSize"
                      grid_size_y="MTC_ScintCellSize"
                      offset_x="-(MTC_max_env_width/2.0)+0.001*mm"
                      offset_y="-(MTC_max_env_width/2.0)+0.001*mm"/>
      </segmentation>
      <!-- plane:2 = 2 bits for values 0,1,2; strip for SciFi; x,y for Scint -->
      <id>system:8,station:2,layer:8,slice:4,plane:2,strip:14,x:9,y:9</id>
    </readout>

    <readout name="SiTargetHits">
      <!-- MultiSegmentation selects strip direction based on plane field:
           plane=0 → CartesianStripX (measures X coordinate)
           plane=1 → CartesianStripY (measures Y coordinate)
           column: 0-3 (4 columns in X), row: 0-1 (2 rows in Y)
           strip: strip index within the sensor (up to 1298 strips) -->
      <segmentation type="MultiSegmentation" key="plane">
        <segmentation type="CartesianStripX"
                      key_value="0"
                      strip_size_x="SiTarget_strip_pitch"
                      offset_x="-(SiTarget_env_width/2.0)+0.001*mm"/>
        <segmentation type="CartesianStripY"
                      key_value="1"
                      strip_size_x="SiTarget_strip_pitch"
                      offset_x="-(SiTarget_env_height/2.0)+0.001*mm"/>
      </segmentation>
      <id>system:8,layer:8,slice:4,plane:1,column:2,row:2,strip:14</id>
    </readout>
  </readouts>

  <detectors>
    <include ref="SiPadDetector.xml"/>
    <include ref="SiTarget.xml"/>
    <include ref="MTCDetector.xml"/>
  </detectors>


</lccdd>
